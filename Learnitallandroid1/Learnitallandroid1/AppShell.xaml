<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Learnitallandroid1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Learnitallandroid1.Views.Auth"
    xmlns:menuViews="clr-namespace:Learnitallandroid1.Views.Menu"
    Shell.FlyoutBehavior="Disabled"
    Title="Learnitallandroid1">

    <ShellContent
        Route="AuthView"
        ContentTemplate="{DataTemplate views:AuthView}" />

    <ShellContent
        Route="IndexView"
        ContentTemplate="{DataTemplate menuViews:IndexView}" />
</Shell>