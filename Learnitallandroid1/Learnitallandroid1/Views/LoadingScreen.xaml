<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
    x:Class="Learnitallandroid1.Views.LoadingScreen">

    <Grid x:Name="Root"
          BackgroundColor="#000000"
          Opacity="0"
          IsVisible="False"
          InputTransparent="False">

        <Grid HorizontalOptions="Center"
              VerticalOptions="Center"
              WidthRequest="170"
              HeightRequest="170">

            <Border x:Name="LoaderCircle"
                    WidthRequest="150"
                    HeightRequest="150"
                    BackgroundColor="White"
                    Stroke="#E9EEF5"
                    StrokeThickness="1"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Opacity="0"
                    Scale="0.82">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="75" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,10"
                            Radius="24"
                            Opacity="0.22" />
                </Border.Shadow>

                <Grid>

                    <Border WidthRequest="104"
                            HeightRequest="104"
                            BackgroundColor="#F8FAFC"
                            StrokeThickness="0"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="52" />
                        </Border.StrokeShape>
                    </Border>

                    <Grid x:Name="SpinnerHost"
                          WidthRequest="120"
                          HeightRequest="120"
                          HorizontalOptions="Center"
                          VerticalOptions="Center">

                        <Ellipse Stroke="#E9EEF5"
                                 StrokeThickness="6"
                                 WidthRequest="120"
                                 HeightRequest="120"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />

                        <Path x:Name="SpinnerArc"
                              Stroke="#FF8110"
                              StrokeThickness="6"
                              Aspect="Uniform"
                              HorizontalOptions="Center"
                              VerticalOptions="Center"
                              StrokeLineCap="Round"
                              Data="M 60,8 A 52,52 0 1 1 104,34" />
                    </Grid>

                    <Image x:Name="LogoImage"
                           Source="app_logo.png"
                           WidthRequest="58"
                           HeightRequest="58"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Scale="0.96" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentView>