<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Learnitallandroid1.Views.LoadingScreen">

    <Grid x:Name="Root"
          BackgroundColor="#99000000"
          IsVisible="False">

        <Border
            x:Name="LoaderCircle"
            WidthRequest="140"
            HeightRequest="140"
            StrokeShape="Ellipse"
            BackgroundColor="White"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Opacity="0"
            Scale="0.85">

            <Grid>

                <Border
                    x:Name="SpinnerRing"
                    Stroke="#FF8110"
                    StrokeThickness="4"
                    StrokeShape="Ellipse" />

                <Image
                    Source="app_logo.png"
                    WidthRequest="64"
                    HeightRequest="64"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />

            </Grid>

        </Border>

    </Grid>
</ContentView>