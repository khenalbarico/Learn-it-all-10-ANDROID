<?xml version="1.0" encoding="utf-8" ?>
<base:AuthPage1
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:Learnitallandroid1.Views"
    x:DataType="base:BasePage1"
    x:Class="Learnitallandroid1.Views.Authentication.LoginRegister"
    BackgroundColor="#F8FAFC"
    Shell.NavBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout Padding="24,34,24,24" Spacing="24">

            <Border BackgroundColor="#EEF4FB"
                    StrokeThickness="0"
                    Padding="6">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">

                    <Button x:Name="LoginTabButton"
                            Grid.Column="0"
                            Text="Login"
                            Clicked="OnLoginTabClicked"
                            HeightRequest="50"
                            CornerRadius="18"
                            FontSize="18"
                            FontAttributes="Bold"
                            BackgroundColor="#FF9A4D"
                            TextColor="White" />

                    <Button x:Name="RegisterTabButton"
                            Grid.Column="1"
                            Text="Register"
                            Clicked="OnRegisterTabClicked"
                            HeightRequest="50"
                            CornerRadius="18"
                            FontSize="18"
                            FontAttributes="Bold"
                            BackgroundColor="Transparent"
                            TextColor="#0A58B6" />
                </Grid>
            </Border>

            <Border BackgroundColor="White"
                    Stroke="#E9EEF5"
                    StrokeThickness="1"
                    Padding="24">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#180A58B6"
                            Offset="0,8"
                            Radius="18"
                            Opacity="0.18" />
                </Border.Shadow>

                <Grid>
                    <VerticalStackLayout x:Name="LoginSection"
                                         IsVisible="True"
                                         Opacity="1"
                                         Spacing="18">

                        <Label Text="Sign in"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="#1F2A44" />

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Email"
                                   FontSize="14"
                                   TextColor="#334155" />

                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#E2E8F0"
                                    StrokeThickness="1"
                                    Padding="16,12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>

                                <Entry x:Name="LoginEmailEntry"
                                       Placeholder="Enter your email"
                                       PlaceholderColor="#94A3B8"
                                       TextColor="#1F2A44"
                                       Keyboard="Email" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Password"
                                   FontSize="14"
                                   TextColor="#334155" />

                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#E2E8F0"
                                    StrokeThickness="1"
                                    Padding="16,12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>

                                <Entry x:Name="LoginPasswordEntry"
                                       Placeholder="Enter your password"
                                       PlaceholderColor="#94A3B8"
                                       TextColor="#1F2A44"
                                       IsPassword="True"
                                       TextChanged="OnLoginPasswordChanged" />
                            </Border>
                        </VerticalStackLayout>

                        <Label Text="Forgot Password?"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#0A58B6"
                               HorizontalOptions="End" />

                        <Button Text="Login"
                                HeightRequest="58"
                                CornerRadius="20"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="White"
                                BackgroundColor="#FF9A4D" />
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="RegisterSection"
                                         IsVisible="False"
                                         Opacity="0"
                                         Spacing="18">

                        <Label Text="Create account"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="#1F2A44" />

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Email"
                                   FontSize="14"
                                   TextColor="#334155" />

                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#E2E8F0"
                                    StrokeThickness="1"
                                    Padding="16,12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>

                                <Entry x:Name="RegisterEmailEntry"
                                       Placeholder="Enter your email"
                                       PlaceholderColor="#94A3B8"
                                       TextColor="#1F2A44"
                                       Keyboard="Email" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Confirm Email"
                                   FontSize="14"
                                   TextColor="#334155" />

                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#E2E8F0"
                                    StrokeThickness="1"
                                    Padding="16,12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>

                                <Entry x:Name="RegisterConfirmEmailEntry"
                                       Placeholder="Confirm your email"
                                       PlaceholderColor="#94A3B8"
                                       TextColor="#1F2A44"
                                       Keyboard="Email" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Password"
                                   FontSize="14"
                                   TextColor="#334155" />

                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#E2E8F0"
                                    StrokeThickness="1"
                                    Padding="16,12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>

                                <Entry x:Name="RegisterPasswordEntry"
                                       Placeholder="Create a password"
                                       PlaceholderColor="#94A3B8"
                                       TextColor="#1F2A44"
                                       IsPassword="True"
                                       TextChanged="OnRegisterPasswordChanged" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Confirm Password"
                                   FontSize="14"
                                   TextColor="#334155" />

                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#E2E8F0"
                                    StrokeThickness="1"
                                    Padding="16,12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>

                                <Entry x:Name="RegisterConfirmPasswordEntry"
                                       Placeholder="Confirm your password"
                                       PlaceholderColor="#94A3B8"
                                       TextColor="#1F2A44"
                                       IsPassword="True"
                                       TextChanged="OnRegisterConfirmPasswordChanged" />
                            </Border>
                        </VerticalStackLayout>

                        <Button Text="Sign Up"
                                HeightRequest="58"
                                CornerRadius="20"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="White"
                                BackgroundColor="#0A58B6" />

                        <Label HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"
                               FontSize="13"
                               TextColor="#667085">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="By signing up, you agree to our " />
                                    <Span Text="Terms"
                                          TextColor="#FF9A4D"
                                          FontAttributes="Bold" />
                                    <Span Text=" &amp; " />
                                    <Span Text="Privacy Policy"
                                          TextColor="#0A58B6"
                                          FontAttributes="Bold" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</base:AuthPage1>