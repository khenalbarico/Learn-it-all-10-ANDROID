<?xml version="1.0" encoding="utf-8" ?>
<base:AuthPage1
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:Learnitallandroid1.Views"
    xmlns:views="clr-namespace:Learnitallandroid1.Views"
    x:DataType="base:BasePage1"
    x:Class="Learnitallandroid1.Views.Authentication.Welcome"
    BackgroundColor="#F8FAFC">

    <Grid>
        <Grid RowDefinitions="Auto,*,Auto"
              Padding="24"
              Opacity="0"
              x:Name="RootGrid">

            <Label
                x:Name="TitleLabel"
                Grid.Row="0"
                Text="Welcome!"
                TextColor="#1F2A44"
                FontSize="34"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                Margin="0,40,0,20"
                TranslationY="-20" />

            <VerticalStackLayout
                Grid.Row="1"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="12"
                Scale="0.8"
                x:Name="LogoSection">

                <Border BackgroundColor="White"
                        Stroke="#E9EEF5"
                        StrokeThickness="1"
                        Padding="28">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#180A58B6"
                                Offset="0,8"
                                Radius="18"
                                Opacity="0.16" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="12">
                        <Image
                            Source="app_logo.png"
                            HeightRequest="140"
                            Aspect="AspectFit" />

                        <Label
                            Text="RE-LEARN 41"
                            TextColor="#1F2A44"
                            FontSize="18"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout
                Grid.Row="2"
                Spacing="18"
                Margin="0,0,0,40"
                HorizontalOptions="Center"
                TranslationY="40"
                x:Name="ButtonsSection">

                <Border
                    StrokeShape="RoundRectangle 28"
                    HeightRequest="56"
                    WidthRequest="280">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#57D6E5" Offset="0.0" />
                            <GradientStop Color="#0A58B6" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Button
                        Text="Continue without account"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        Clicked="OnContinueClicked"
                        Pressed="OnButtonPressed"
                        Released="OnButtonReleased" />
                </Border>

                <Label
                    Text="or"
                    TextColor="#64748B"
                    FontSize="14"
                    HorizontalOptions="Center" />

                <Border
                    StrokeShape="RoundRectangle 28"
                    HeightRequest="56"
                    WidthRequest="280">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFDE59" Offset="0.0" />
                            <GradientStop Color="#FF914D" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Button
                        Text="Login using an existing account"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        Clicked="OnLoginClicked"
                        Pressed="OnButtonPressed"
                        Released="OnButtonReleased" />
                </Border>

            </VerticalStackLayout>
        </Grid>
        <views:LoadingScreen IsLoading="{Binding IsLoadingVisible}" />
    </Grid>
</base:AuthPage1>