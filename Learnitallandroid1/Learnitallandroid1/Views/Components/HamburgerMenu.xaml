<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Learnitallandroid1.Views.App.HamburgerMenu">

    <Grid Padding="20,40,20,20"
          RowDefinitions="Auto,Auto,Auto,*"
          BackgroundColor="#F5F7FB"
          WidthRequest="220">

        <HorizontalStackLayout Grid.Row="0" Spacing="12" Margin="0,0,0,25">
            <Label Text="☰"
                   FontSize="24"
                   VerticalOptions="Center"
                   TextColor="#1F2A44" />
            <Label Text="Menu"
                   FontSize="22"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   TextColor="#1F2A44" />
        </HorizontalStackLayout>

        <Border Grid.Row="1"
                StrokeShape="RoundRectangle 14"
                BackgroundColor="#1565C0"
                Padding="14,12"
                Margin="0,0,0,12">
            <HorizontalStackLayout Spacing="12">
                <Label Text="📚"
                       FontSize="20"
                       VerticalOptions="Center"
                       TextColor="White" />
                <Label Text="Library"
                       FontSize="18"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="White" />
            </HorizontalStackLayout>
        </Border>

        <Border Grid.Row="2"
                StrokeShape="RoundRectangle 14"
                BackgroundColor="Transparent"
                Padding="14,12"
                Margin="0,0,0,12">
            <HorizontalStackLayout Spacing="12">
                <Label Text="🛒"
                       FontSize="20"
                       VerticalOptions="Center"
                       TextColor="#1F2A44" />
                <Label Text="Purchases"
                       FontSize="18"
                       VerticalOptions="Center"
                       TextColor="#1F2A44" />
            </HorizontalStackLayout>
        </Border>

        <Border Grid.Row="3"
                StrokeShape="RoundRectangle 14"
                BackgroundColor="Transparent"
                Padding="14,12"
                VerticalOptions="Start">
            <HorizontalStackLayout Spacing="12">
                <Label Text="👤"
                       FontSize="20"
                       VerticalOptions="Center"
                       TextColor="#1F2A44" />
                <Label Text="Account"
                       FontSize="18"
                       VerticalOptions="Center"
                       TextColor="#1F2A44" />
            </HorizontalStackLayout>
        </Border>

    </Grid>
</ContentView>